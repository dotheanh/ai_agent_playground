# bot-chat environment template
# Copy this file to .env (DO NOT commit .env)

# Bot-chat server
PORT=3010
HISTORY_MAX_MESSAGES=1000

# Mention settings
MENTION_NAME=alex

# LLM provider config for alex auto connector
# This matches your config structure:
# providers.local.baseUrl, providers.local.apiKey, providers.local.api, providers.local.models[0].id
LLM_PROVIDER=local
LLM_BASE_URL=https://chat.zingplay.com/api
LLM_API_KEY=
LLM_API=openai-chat-completions
LLM_MODEL_ID=local-model

# Reply style
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=400
