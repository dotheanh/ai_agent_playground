# ============================================
# Zingplay - serve ZPS tại root (/)
# ============================================
zingplay.duckdns.org {
	# API routes first - must be before file_server
	handle /api/* {
		reverse_proxy localhost:3001
	}

	# ZPS also uses /portal/api/* (from .env.production)
	handle /portal/api/* {
		uri strip_prefix /portal
		reverse_proxy localhost:3001
	}

	# Static files for SPA
	handle {
		root * /var/www/tools/zps/client/dist
		try_files {path} {path}/ /index.html
		file_server
	}
}

# ============================================
# Tools - serve Portal tại /portal/
# ============================================
nhoxtheanh.duckdns.org {
	@mp4 path *.mp4
	header @mp4 Content-Type video/mp4

	# Bot Chat - WebSocket chat room
	handle_path /boman/* {
		reverse_proxy localhost:3010 {
			header_up Host {upstream_hostport}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Bot Chat root path
	handle /boman {
		reverse_proxy localhost:3010 {
			header_up Host {upstream_hostport}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Portal API
	handle /portal/api/* {
		uri strip_prefix /portal
		reverse_proxy localhost:3001
	}

	# Portal React frontend (base: /portal/)
	handle_path /portal/* {
		root * /var/www/tools/portal/client/dist
		try_files {path} {path}/ /index.html
		file_server
	}

	# Gunny game
	handle_path /gunny/* {
		root * /var/www/tools/gunny
		file_server
	}

	# Root files
	handle {
		root * /var/www/tools
		file_server
	}
}
