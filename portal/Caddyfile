# ============================================
# Zingplay - serve ZPS tại root (/)
# ============================================
zingplay.duckdns.org {
	root * /var/www/tools/zps/client/dist
	file_server

	# ZPS API proxy
	handle /api/* {
		reverse_proxy localhost:3001
	}

	# ZPS also uses /portal/api/* (from .env.production)
	handle /portal/api/* {
		uri strip_prefix /portal
		reverse_proxy localhost:3001
	}

	try_files {path} {path}/ /index.html
}

# ============================================
# Tools - serve Portal tại /portal/
# ============================================
nhoxtheanh.duckdns.org {

	root * /var/www/tools
	file_server

	@mp4 path *.mp4
	header @mp4 Content-Type video/mp4

	# Portal API
	handle /portal/api/* {
		uri strip_prefix /portal
		reverse_proxy localhost:3001
	}

	# Portal React frontend (base: /portal/)
	handle_path /portal/* {
		root * /var/www/tools/portal/client/dist
		try_files {path} {path}/ /index.html
		file_server
	}

	# Gunny game
	handle_path /gunny/* {
		root * /var/www/tools/gunny
		file_server
	}
}
