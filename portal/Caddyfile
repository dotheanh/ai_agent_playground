# ============================================
# Zingplay - serve ZPS tại root (/)
# ============================================
zingplay.duckdns.org {
	# API proxy (must be separate handles so they run before static files)
	handle /api/* {
		reverse_proxy localhost:3001
	}

	handle /portal/api/* {
		uri strip_prefix /portal
		reverse_proxy localhost:3001
	}

	# Static files + SPA fallback (catch-all, runs only if no API match)
	handle {
		root * /var/www/tools/zps/client/dist
		try_files {path} {path}/ /index.html
		file_server
	}
}

# ============================================
# Tools - serve Portal tại /portal/
# ============================================
nhoxtheanh.duckdns.org {

	root * /var/www/tools
	file_server

	@mp4 path *.mp4
	header @mp4 Content-Type video/mp4

	# Bot Chat - WebSocket chat room
	handle_path /boman/* {
		reverse_proxy localhost:3010
	}

	# Bot Chat WebSocket upgrade support
	handle /boman {
		reverse_proxy localhost:3010
	}

	# Portal API
	handle /portal/api/* {
		uri strip_prefix /portal
		reverse_proxy localhost:3001
	}

	# Portal React frontend (base: /portal/)
	handle_path /portal/* {
		root * /var/www/tools/portal/client/dist
		try_files {path} {path}/ /index.html
		file_server
	}

	# Gunny game
	handle_path /gunny/* {
		root * /var/www/tools/gunny
		file_server
	}
}
